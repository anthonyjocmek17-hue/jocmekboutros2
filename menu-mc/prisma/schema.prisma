generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String   @default("ADMIN") // ADMIN | KITCHEN | WAITER | TABLE
  tableId      String?
  table        Table?   @relation(fields: [tableId], references: [id], onDelete: SetNull)
  orders       Order[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tableId])
}

model Table {
  id        String @id @default(cuid())
  label     String @unique // e.g. "Table 1"
  users     User[]
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id        String     @id @default(cuid())
  name      String     @unique
  sortOrder Int        @default(0)
  items     MenuItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model MenuItem {
  id          String    @id @default(cuid())
  name        String
  description String?
  /** Comma- or newline-separated; used by the menu assistant for search and suggestions. */
  ingredients String?
  price       String?
  isAvailable Boolean   @default(true)
  isOutOfStock Boolean  @default(false)
  prepTimeMinutes Int   @default(10)
  sortOrder   Int       @default(0)
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([categoryId])
}

model Order {
  id        String       @id @default(cuid())
  status    OrderStatus  @default(NEW)
  note      String?
  estimatedReadyAt DateTime?
  startedAt DateTime?
  readyAt   DateTime?
  completedAt DateTime?
  deliveredAt DateTime?
  totalCents Int         @default(0)
  voucherCode String?
  voucherDiscountCents Int @default(0)
  manualDiscountCents Int @default(0)
  finalTotalCents Int @default(0)
  // When set, `finalTotalCents` follows this instead of subtotal − voucher − manual.
  finalTotalOverrideCents Int?
  isPaid    Boolean      @default(false)
  paidAt    DateTime?

  tableId   String
  table     Table        @relation(fields: [tableId], references: [id], onDelete: Cascade)

  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  items     OrderItem[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([status, createdAt])
  @@index([tableId, createdAt])
  @@index([userId, createdAt])
}

model Voucher {
  id        String @id @default(cuid())
  code      String @unique
  type      VoucherType
  amountCents Int?
  percent   Int? // 1..100
  isActive  Boolean @default(true)
  expiresAt DateTime?
  maxUses   Int?
  usesCount Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum VoucherType {
  AMOUNT
  PERCENT
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  menuItemId String?
  menuItem   MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)

  name      String
  price     String?
  quantity  Int     @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([menuItemId])
}

enum OrderStatus {
  NEW
  IN_PROGRESS
  READY
  COMPLETED
  CANCELLED
}

