DATABASE_URL="file:./dev.db"
# Must match the exact origin you open in the browser (scheme + host + port), e.g. http://127.0.0.1:3000 vs http://localhost:3000
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-in-production"

# Optional: how many `Table N` + `tableN@menu.local` accounts `npm run seed` creates (default 13).
# SEED_TABLE_COUNT="13"

# Optional: dedicated secret for signing table QR login URLs (defaults to NEXTAUTH_SECRET if unset).
# TABLE_QR_SECRET=""

# OpenAI — used by /api/chat (floating Chat widget). Do not commit real keys; copy this file to .env and fill in.
OPENAI_API_KEY=""
# Optional overrides:
# OPENAI_MODEL="gpt-4o-mini"
# OPENAI_BASE_URL="https://api.openai.com/v1"

